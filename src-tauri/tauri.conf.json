{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CCNim",
  "version": "0.3.1",
  "identifier": "dev.ccnim.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CCNim",
        "width": 1180,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/512x512.png",
      "icons/512x512@2x.png"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/HG-ha/ccnim/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1NzY0RUM1MDZDRTA3RTQKUldUa0I4NEd4VTUyUmZuNkxxV05LS2dmb2FISG5aNkltN2orb3lHdzBmZTNWT25lbW1aNXBtSkUK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}